{
  "manifest_version": 3,
  "name": "RSS Feed Finder",
  "version": "1.0",
  "description": "Finds and copies the RSS feed URL from any webpage.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icons/icon48.png"
  },
  "permissions": ["activeTab", "scripting"]
}
